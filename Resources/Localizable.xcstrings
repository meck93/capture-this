    "Enables verbose logging and lets the app's own windows (popover, HUD, settings) appear in screen captures. Leave off for normal use." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviert ausführliche Logs und zeigt App-Fenster (Popover, HUD, Einstellungen) in Bildschirmaufnahmen. Für normale Nutzung deaktiviert lassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enables verbose logging and lets the app's own windows (popover, HUD, settings) appear in screen captures. Leave off for normal use."
          }
        }
      }
